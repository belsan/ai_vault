# =============================================================
# .env.example --- template for query_llm.py configuration
#
# Copy to .env and fill in the lines you need. The .env file is
# git-ignored at the repo root; .env.example is committed so the
# variables the wrapper looks for are documented in one place.
#
# Setup:
#   cp .env.example .env
#   $EDITOR .env
# =============================================================

# Which backend query_llm dispatches to.
# One of: ollama | openai | anthropic. Defaults to ollama.
LLM_BACKEND=ollama


# --- Ollama (local or remote) -------------------------------------
# URL of the Ollama server. Default localhost is fine for a normal
# `ollama serve`. Point this at a RunPod / Vast / Modal URL when the
# GPU lives in someone else's data centre.
OLLAMA_BASE_URL=http://localhost:11434

# Default model passed to Ollama. Override per-call via the `model`
# argument to query_llm / ask_llm.
OLLAMA_MODEL=gemma4:e4b


# --- OpenAI -------------------------------------------------------
# Required if LLM_BACKEND=openai.
# OPENAI_API_KEY=sk-...


# --- Anthropic ----------------------------------------------------
# Required if LLM_BACKEND=anthropic.
# ANTHROPIC_API_KEY=sk-ant-...
